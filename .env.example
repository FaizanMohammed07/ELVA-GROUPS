# ============================================================
# ELVA — Environment Variables Template
# Copy to .env and fill in your values. NEVER commit .env
# ============================================================

# App
NODE_ENV=development
APP_NAME=ELVA
APP_URL=http://localhost:3000
API_URL=http://localhost:5000
PORT=5000
FRONTEND_URL=http://localhost:3000
API_VERSION=v1

# ============================================================
# DATABASE
# ============================================================
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/elva?retryWrites=true&w=majority
MONGODB_DB_NAME=elva

# ============================================================
# REDIS
# ============================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TTL=3600

# ============================================================
# JWT
# ============================================================
JWT_ACCESS_SECRET=your-super-secret-access-key-min-64-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-64-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================
# COOKIE
# ============================================================
COOKIE_SECRET=your-cookie-secret-key-min-32-chars
COOKIE_DOMAIN=localhost

# ============================================================
# AWS S3
# ============================================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=elva-media
AWS_S3_CDN_URL=https://cdn.elva.in

# ============================================================
# RAZORPAY
# ============================================================
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ============================================================
# EMAIL — RESEND
# ============================================================
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=hello@elva.in
RESEND_FROM_NAME=ELVA

# ============================================================
# EMAIL — NODEMAILER (SMTP fallback)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ============================================================
# FIREBASE (Push Notifications)
# ============================================================
FIREBASE_PROJECT_ID=elva-firebase
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@elva.iam.gserviceaccount.com

# ============================================================
# WHATSAPP (via Interakt / WATI / official API)
# ============================================================
WHATSAPP_API_URL=https://api.interakt.ai
WHATSAPP_API_KEY=your-whatsapp-api-key

# ============================================================
# SMS (via Fast2SMS / MSG91)
# ============================================================
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=ELVAIN

# ============================================================
# GOOGLE OAUTH
# ============================================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ============================================================
# ELASTICSEARCH (optional — Algolia alternative)
# ============================================================
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=elva_products

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================
# SECURITY
# ============================================================
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret-min-32-chars
ALLOWED_ORIGINS=http://localhost:3000,https://elva.in

# ============================================================
# MONITORING
# ============================================================
SENTRY_DSN=https://xxxx@sentry.io/xxxx
LOG_LEVEL=debug

# ============================================================
# AI (for future AI personalization)
# ============================================================
OPENAI_API_KEY=sk-xxxxxxxxxxxx
